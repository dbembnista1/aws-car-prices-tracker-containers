# DEV backend — the state bucket is CREATED by environments/dev/bootstrap
# (name includes a random suffix, known only after apply). Copy to backend.conf
# and fill in real values, or let deploy-dev generate backend.conf from
# environments/dev/bootstrap outputs.
bucket         = "car-prices-terraform-state-XXXXXX"
key            = "terraform.tfstate"
region         = "eu-central-1"
dynamodb_table = "car-prices-terraform-locks"
encrypt        = true
